// SQLite-compatible database schema for Freelance Flow
// Supports all CRUD operations for projects, clients, tasks, and payments

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE AUTHENTICATION & IDENTITY
// ============================================================================

/// Users table - Core authentication and identity management
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          String   @default("freelancer")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  clients       Client[]
  activityLogs  ActivityLog[]

  @@index([email])
  @@map("users")
}

// ============================================================================
// CLIENT MANAGEMENT
// ============================================================================

/// Clients table - Client/Company profiles
model Client {
  id            String   @id @default(cuid())
  userId        String
  name          String
  email         String
  company       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Foreign keys
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  projects      Project[]

  @@index([userId])
  @@map("clients")
}

// ============================================================================
// PROJECT MANAGEMENT
// ============================================================================

/// Projects table - Project management with budget and timeline tracking
model Project {
  id            String   @id @default(cuid())
  userId        String
  clientId      String
  name          String
  description   String?
  budget        Float
  status        String   @default("ONGOING")
  priority      String   @default("MEDIUM")
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Foreign keys
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Relations
  payments      Payment[]
  tasks         Task[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@map("projects")
}

// ============================================================================
// FINANCIAL TRACKING
// ============================================================================

/// Payments table - Invoice and payment tracking with status management
model Payment {
  id            String   @id @default(cuid())
  projectId     String
  amount        Float
  currency      String   @default("USD")
  invoiceNumber String   @unique
  status        String   @default("PENDING")
  dueDate       DateTime
  paidDate      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Foreign keys
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([invoiceNumber])
  @@map("payments")
}

// ============================================================================
// TASK MANAGEMENT
// ============================================================================

/// Tasks table - Task tracking with deadline management
model Task {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  status        String   @default("PENDING")
  deadline      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Foreign keys
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@map("tasks")
}

// ============================================================================
// AUDIT & LOGGING
// ============================================================================

/// Activity Logs table - Audit trail for all user activities
model ActivityLog {
  id            String   @id @default(cuid())
  userId        String
  action        String
  timestamp     DateTime @default(now())
  details       String?

  // Foreign keys
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@map("activity_logs")
}
