// Production-grade 3NF PostgreSQL database schema with Prisma ORM
// Includes normalized data model, relationships, cascade deletes, and indexes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE AUTHENTICATION & IDENTITY
// ============================================================================

/// Users table - Core authentication and identity management
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  client        Client?
  activityLogs  ActivityLog[]

  @@index([email])
  @@map("users")
}

// ============================================================================
// CLIENT MANAGEMENT
// ============================================================================

/// Clients table - Client/Company profiles (1:1 relationship with users)
model Client {
  id            String   @id @default(cuid())
  userId        String   @unique
  name          String
  email         String
  company       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Foreign keys
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  projects      Project[]

  @@index([userId])
  @@map("clients")
}

// ============================================================================
// PROJECT MANAGEMENT
// ============================================================================

/// Projects table - Project management with budget and timeline tracking
model Project {
  id            String   @id @default(cuid())
  clientId      String
  name          String
  description   String?
  budget        Decimal
  status        ProjectStatus @default(ONGOING)
  priority      Priority @default(MEDIUM)
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Foreign keys
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Relations
  payments      Payment[]
  tasks         Task[]

  @@index([clientId])
  @@map("projects")
}

// ============================================================================
// FINANCIAL TRACKING
// ============================================================================

/// Payments table - Invoice and payment tracking with status management
model Payment {
  id            String   @id @default(cuid())
  projectId     String
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("USD") @db.VarChar(3)
  invoiceNumber String   @unique @db.VarChar(255)
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime @db.Timestamp(3)
  paidDate      DateTime? @db.Timestamp(3)
  createdAt     DateTime @default(now()) @db.Timestamp(3)
  updatedAt     DateTime @updatedAt @db.Timestamp(3)

  // Foreign keys
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([invoiceNumber])
  @@map("payments")
}

// ============================================================================
// TASK MANAGEMENT
// ============================================================================

/// Tasks table - Task tracking with deadline management
model Task {
  id            String   @id @default(cuid())
  projectId     String
  title         String   @db.VarChar(255)
  status        TaskStatus @default(PENDING)
  deadline      DateTime? @db.Timestamp(3)
  createdAt     DateTime @default(now()) @db.Timestamp(3)
  updatedAt     DateTime @updatedAt @db.Timestamp(3)

  // Foreign keys
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@map("tasks")
}

// ============================================================================
// AUDIT & LOGGING
// ============================================================================

/// Activity Logs table - Audit trail for all user activities
model ActivityLog {
  id            String   @id @default(cuid())
  userId        String
  action        String   @db.VarChar(255)
  timestamp     DateTime @default(now()) @db.Timestamp(3)
  details       String?  @db.Text

  // Foreign keys
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@map("activity_logs")
}

// ============================================================================
// ENUMS - Type constraints for data integrity
// ============================================================================

enum ProjectStatus {
  ONGOING
  COMPLETED

  @@map("project_status")
}

enum Priority {
  LOW
  MEDIUM
  HIGH

  @@map("priority")
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE

  @@map("payment_status")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("task_status")
}
